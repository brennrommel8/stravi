{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "types": ["node"],
    "paths": {
      "stravi": ["./src/index.ts"],
      "stravi/cors": ["./src/middleware/cors/index.ts"],
      "stravi/validator": ["./src/validator/index.ts"],
      "stravi/static": ["./src/middleware/static/index.ts"],
      "stravi/logger": ["./src/middleware/logger/index.ts"],
      "stravi/security": ["./src/middleware/security/index.ts"],
      "stravi/dev": ["./src/dev/index.ts"]
    },
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "examples/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
