{
  "name": "stravi",
  "version": "0.0.6",
  "description": "Stravi lightweight Node.js backend framework",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./cors": {
      "types": "./dist/src/middleware/cors/index.d.ts",
      "default": "./dist/src/middleware/cors/index.js"
    },
    "./validator": {
      "types": "./dist/src/validator/index.d.ts",
      "default": "./dist/src/validator/index.js"
    },
    "./static": {
      "types": "./dist/src/middleware/static/index.d.ts",
      "default": "./dist/src/middleware/static/index.js"
    },
    "./logger": {
      "types": "./dist/src/middleware/logger/index.d.ts",
      "default": "./dist/src/middleware/logger/index.js"
    },
    "./security": {
      "types": "./dist/src/middleware/security/index.d.ts",
      "default": "./dist/src/middleware/security/index.js"
    },
    "./dev": {
      "default": "./dist/src/dev/index.js"
    }
  },
  "bin": {
    "stravi-dev": "dist/src/dev/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test",
    "bench": "npm run build && node benchmarks/run.js",
    "bench:quick": "npm run build && node benchmarks/run.js --duration 10 --connections 50 --pipelining 1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tsx": "^4.20.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "autocannon": "^8.0.0",
    "typescript": "^5.8.3",
    "zod": "^4.4.3"
  },
  "keywords": [
    "stravi",
    "framework",
    "node",
    "http"
  ],
  "license": "MIT"
}
